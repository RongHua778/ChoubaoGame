{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CardLoot: 启动本地服务器",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "cardloot-serve",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Accepting connections"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "CardLoot: 打开浏览器预览",
      "type": "shell",
      "command": "cmd /c start \"\" \"http://127.0.0.1:5173\"",
      "problemMatcher": [],
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "CardLoot: 一键启动预览（含浏览器）",
      "type": "shell",
      "command": "${workspaceFolder}\\启动预览.bat",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
